<Window x:Class="Pr7._2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pr7._2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <StackPanel>

            <TextBlock Text="Шифр Виженера"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Введите текст:"/>
            <TextBox x:Name="txtInput"
                     Height="90"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     ToolTip="Введите текст для шифрования или дешифрования"/>

            <TextBlock Text="Ключ:"
                       Margin="0,10,0,0"/>
            <TextBox x:Name="txtKey"
                     ToolTip="Ключ должен содержать английские буквы"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,15,0,0">
                <Button Content="Зашифровать"
                        Width="130"
                        Height="35"
                        Click="Encrypt_Click"/>

                <Button Content="Расшифровать"
                        Width="130"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="Decrypt_Click"/>

                <Button Content="Очистить"
                        Width="100"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="Clear_Click"/>
            </StackPanel>

            <TextBlock Text="Результат:"
                       Margin="0,15,0,0"/>
            <TextBox x:Name="txtOutput"
                     Height="90"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     IsReadOnly="True"/>

        </StackPanel>
    </Grid>
</Window>
